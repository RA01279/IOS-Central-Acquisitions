# Supabase (shared project with RIDGE Intel, or standalone -- see architecture notes)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Same values, exposed to the browser for the login page. The anon key
# is safe client-side by design -- it's rate-limited and has no access
# without a valid user session.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Comma-separated emails allowed to confirm "Moving to PSA"
PSA_CONFIRM_ALLOWLIST=rhett@dalfen.com,john@dalfen.com

# Auth: create your 3 users directly in the Supabase dashboard
# (Authentication -> Users -> Add user). No IT approval, no app
# registration -- works today. If this later needs Dalfen SSO, that's
# a swap of lib/auth.ts only.
